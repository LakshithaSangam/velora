# Database — recommended: free Postgres at neon.com, paste your connection string here.
# Or for local Postgres via Docker: docker compose up, then this default works as-is.
# If using Neon: drop the "&channel_binding=require" param Neon adds by default —
# Prisma's engine can't parse it and fails with a cryptic "invalid digit found in
# string" error. Keep "?sslmode=require", just remove the channel_binding part.
DATABASE_URL="postgresql://studynotes:studynotes@localhost:5432/studynotes"

# NextAuth
AUTH_SECRET="" # generate with: npx auth secret
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Google Gemini (notes/test/grading generation) — free tier, no card needed.
# Get a key at aistudio.google.com -> "Get API key" -> "Create API key".
GEMINI_API_KEY=""
GEMINI_MODEL_NOTES="gemini-flash-lite-latest"
GEMINI_MODEL_TEST_GEN="gemini-flash-lite-latest"
GEMINI_MODEL_GRADING="gemini-flash-lite-latest"
GEMINI_MODEL_CHAT="gemini-flash-lite-latest"

# File storage (PDF uploads) — leave blank for local-disk dev storage
BLOB_READ_WRITE_TOKEN=""

# Deepgram (live meeting transcription) — free tier ($200 credit) at console.deepgram.com
DEEPGRAM_API_KEY=""

# OpenAI (Whisper transcription for uploaded audio/video files)
OPENAI_API_KEY=""
