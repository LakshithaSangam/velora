generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth (Auth.js) models ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // null when the user only signs in via Google OAuth
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  sources      Source[]
  notesDocs    NotesDocument[]
  tests        Test[]
  testAttempts TestAttempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application models ─────────────────────────────────────────────────────

enum SourceType {
  YOUTUBE
  GENERIC_VIDEO
  PDF
  WEB_ARTICLE
  PASTED_TRANSCRIPT
  MEETING_RECORDING
  MEDIA_UPLOAD // user-uploaded audio/video file, transcribed via Whisper
  DOCUMENT_UPLOAD // user-uploaded Word (.docx) or Excel (.xlsx) file
}

enum SourceStatus {
  PENDING_CONFIRMATION // raw text/metadata fetched, awaiting user "Yes, generate"
  INGESTING
  READY
  FAILED
}

model Source {
  id           String       @id @default(cuid())
  userId       String
  type         SourceType
  originalUrl  String?
  fileKey      String? // storage key for uploaded PDFs
  title        String?
  rawText      String?      @db.Text
  status       SourceStatus @default(PENDING_CONFIRMATION)
  errorMessage String?
  metadata     Json?
  confirmedAt  DateTime?
  consentConfirmedAt DateTime? // MEETING_RECORDING only — when the user checked the disclosure box
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  notesDocuments NotesDocument[]
  testsAsSource  Test[]          @relation("TestFreshSource")

  @@index([userId])
}

enum GenerationStatus {
  GENERATING
  READY
  FAILED
}

model NotesDocument {
  id           String           @id @default(cuid())
  userId       String
  sourceId     String
  title        String
  sectionsJson Json?
  markdown     String?          @db.Text
  status       GenerationStatus @default(GENERATING)
  model        String?
  errorMessage String?
  tokenUsage   Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  testsAsBasis Test[] @relation("TestNotesSource")

  @@index([userId])
}

enum TestSourceType {
  NOTES_DOCUMENT
  FRESH_UPLOAD
  VIDEO_URL
}

enum QuestionStyle {
  MCQ
  SHORT_ANSWER
  MIXED
}

model Test {
  id                     String           @id @default(cuid())
  userId                 String
  title                  String
  testSourceType         TestSourceType
  notesDocumentId        String?
  sourceId               String? // fresh upload / video URL — reuses the notes pipeline first
  questionStyle          QuestionStyle
  requestedQuestionCount Int
  actualQuestionCount    Int?
  suggestedTimeLimitMin  Int?
  status                 GenerationStatus @default(GENERATING)
  model                  String?
  errorMessage           String?
  createdAt              DateTime         @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notesDocument NotesDocument? @relation("TestNotesSource", fields: [notesDocumentId], references: [id])
  source        Source?        @relation("TestFreshSource", fields: [sourceId], references: [id])
  questions     Question[]
  attempts      TestAttempt[]

  @@index([userId])
}

enum QuestionType {
  MCQ
  SHORT_ANSWER
}

model Question {
  id                 String       @id @default(cuid())
  testId             String
  order              Int
  type               QuestionType
  promptText         String       @db.Text
  options            Json? // string[4] for MCQ, null for SHORT_ANSWER
  correctOptionIndex Int? // MCQ only
  modelAnswer        String?      @db.Text // SHORT_ANSWER reference answer for grading
  points             Int          @default(1)

  test    Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([testId])
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

model TestAttempt {
  id               String        @id @default(cuid())
  testId           String
  userId           String
  startedAt        DateTime      @default(now())
  submittedAt      DateTime?
  timeLimitMinutes Int
  status           AttemptStatus @default(IN_PROGRESS)
  score            Float?
  maxScore         Float?
  createdAt        DateTime      @default(now())

  test    Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([testId])
  @@index([userId])
}

model Answer {
  id                  String    @id @default(cuid())
  testAttemptId       String
  questionId          String
  userAnswerText      String?   @db.Text // SHORT_ANSWER
  selectedOptionIndex Int? // MCQ
  isCorrect           Boolean? // MCQ auto-grade
  gradedScore         Float? // SHORT_ANSWER: 0..1 semantic-match score
  gradingFeedback     String?   @db.Text
  gradedAt            DateTime?

  testAttempt TestAttempt @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([testAttemptId])
  @@index([questionId])
}
